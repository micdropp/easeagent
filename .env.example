# EaseAgent 环境变量配置
# 复制此文件为 .env 并填入真实值

# 阿里云 DashScope API (Phase 3 前获取)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# 飞书开放平台 (Phase 6 前获取)
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook

# MQTT Broker
MQTT_BROKER=localhost
MQTT_PORT=1883

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/easeagent.db
